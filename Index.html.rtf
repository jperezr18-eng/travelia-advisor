 flex-wrap: wrap; margin-bottom: 12px; \} .pill-tag \{ background: var(--gray-light); color: var(--blue-medium); font-size: 0.7rem; padding: 4px 10px; border-radius: 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; \} .pill-tag.budget-pill \{ background: rgba(46, 125, 50, 0.1); color: #2e7d32; \} .itinerary-manifesto \{ font-size: 0.86rem; color: var(--text-main); line-height: 1.45; margin-bottom: 14px; background: #fafbfc; padding: 12px; border-radius: 6px; border: 1px dashed var(--gray-border); \} .agency-attribution-line \{ font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 4px; \} .cta-broker-link \{ display: block; background: var(--blue-deep); color: var(--white); text-decoration: none; text-align: center; padding: 12px; border-radius: 6px; font-size: 0.88rem; font-weight: 700; transition: background 0.2s; \} .cta-broker-link:hover \{ background: var(--earth-tone); \} .reset-workflow-btn \{ background: transparent; border: 2px solid var(--blue-deep); color: var(--blue-deep); padding: 14px; width: 100%; border-radius: 6px; font-weight: 700; cursor: pointer; margin-top: 12px; text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.2s; \} .reset-workflow-btn:hover \{ background: var(--gray-light); \} </style> </head> <body> <div class="app-kiosk-container"> <div class="geo-abstract-layer"> <div class="polygon-canvas-top"></div> <div class="polygon-canvas-bottom"></div> </div> <div class="kiosk-header"> <h1>TravelIA Advisor</h1> <p>Consola de Gesti\'f3n y Calificaci\'f3n de Viajeros</p> </div> <div class="kiosk-progress-track"> <div class="kiosk-progress-fill" id="uiProgressBar"></div> </div> <div class="kiosk-workspace"> <div class="step-panel panel-active" id="panelStage1"> <h2>Paso 1: Clasifique el rango biol\'f3gico/edad del turista</h2> <div class="selection-grid-vertical"> <button class="tile-option-btn" onclick="commitPreference('edad', 'Adolescencia', 2)">Adolescencia</button> <button class="tile-option-btn" onclick="commitPreference('edad', 'Adulto Joven', 2)">Adulto Joven</button> <button class="tile-option-btn" onclick="commitPreference('edad', 'Adulto Maduro', 2)">Adulto Maduro</button> <button class="tile-option-btn" onclick="commitPreference('edad', 'Tercera Edad', 2)">Tercera Edad</button> </div> </div> <div class="step-panel" id="panelStage2"> <h2>Paso 2: \'bfCu\'e1l es la motivaci\'f3n de experiencia del usuario?</h2> <div class="selection-grid-vertical"> <button class="tile-option-btn" onclick="commitPreference('interes', 'Descanso', 3)">Descanso</button> <button class="tile-option-btn" onclick="commitPreference('interes', 'Aventura', 3)">Aventura</button> <button class="tile-option-btn" onclick="commitPreference('interes', 'Planes Extremos', 3)">Planes Extremos</button> <button class="tile-option-btn" onclick="commitPreference('interes', 'Relajaci\'f3n', 3)">Relajaci\'f3n</button> </div> </div> <div class="step-panel" id="panelStage3"> <h2>Paso 3: Seleccione el ecosistema clim\'e1tico predilecto</h2> <div class="selection-grid-vertical"> <button class="tile-option-btn" onclick="commitPreference('clima', 'Selv\'e1tico', 4)">Selv\'e1tico</button> <button class="tile-option-btn" onclick="commitPreference('clima', 'Playa', 4)">Playa</button> <button class="tile-option-btn" onclick="commitPreference('clima', 'Caluroso', 4)">Caluroso</button> <button class="tile-option-btn" onclick="commitPreference('clima', 'Monta\'f1oso', 4)">Monta\'f1oso</button> </div> </div> <div class="step-panel" id="panelStage4"> <h2>Paso 4: Defina el tope m\'e1ximo de inversi\'f3n (USD)</h2> <div class="budget-interactive-area"> <div class="budget-numeric-callout" id="\outl0\strokewidth0 \strokec2 budgetDisplay\outl0\strokewidth0 ">$2500</div> <input type="range" class="budget-input-slider" id="budgetSliderRange" min="600" max="6000" step="100" value="2500" oninput="syncBudgetElement(this.value)"> </div> <button class="action-submit-btn" onclick="processKnowledgeRules()">Computar Destinos \'d3ptimos</button> </div> <div class="step-panel" id="panelStage5"> <h2>Alternativas Globales Recomendadas</h2> <div class="results-scrollable-deck" id="deckSugerencias"></div> <button class="reset-workflow-btn" onclick="rebootWorkflow()">Nueva Calificaci\'f3n</button> </div> </div> </div> <script> // Objeto de Estado Transaccional de la Sesi\'f3n de Usuario let runtimeProfile = \{ edad: '', interes: '', clima: '', presupuesto: 2500 \}; // Base de Conocimiento de Destinos Expandida para Reglas Cruzadas Complejas del Sprint 1 const rulesEngineKnowledgeBase = [ \{ pais: "Costa Rica", clima: "Selv\'e1tico", interes: "Aventura", floorBudget: 1300, plan: "Boleto internacional + Alojamiento en Eco-Lodge sostenible + Ruta guiada de Canopy extremo por el bosque nuboso y trekking al volc\'e1n Arenal.", broker: "Pura Vida Global Journeys Ltd.", channel: "https://wa.me/50688888888" \}, \{ pais: "Brasil", clima: "Caluroso", interes: "Aventura", floorBudget: 1600, plan: "Vuelos ida y vuelta + Hotel con desayuno + Safari de exploraci\'f3n en veh\'edculos abiertos 4x4 por la selva tropical del Amazonas.", broker: "Amazonas Expedition Group", channel: "https://wa.me/5511999999999" \}, \{ pais: "Grecia", clima: "Playa", interes: "Descanso", floorBudget: 2500, plan: "A\'e9reos transatl\'e1nticos clase turista premium + Estancia todo incluido en Resort frente al Mar Egeo (Mykonos) + Crucero diurno.", broker: "Hellenic Premium Leisure", channel: "mailto:reservas@hellenicleisure.gr" \}, \{ pais: "Indonesia", clima: "Playa", interes: "Relajaci\'f3n", floorBudget: 2100, plan: "Tiquetes a\'e9reos integrados + Villa exclusiva con piscina infinita en Ubud (Bali) + Sesiones personalizadas de yoga y meditaci\'f3n.", broker: "IndoBali Serenity Tours", channel: "mailto:support@indobaliserenity.id" \}, \{ pais: "Suiza", clima: "Monta\'f1oso", interes: "Planes Extremos", floorBudget: 3400, plan: "Vuelo transcontinental + Pases de acceso total a los and