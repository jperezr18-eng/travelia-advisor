ncia Estricto (Cruza de Clima, Intereses y Umbral Financiero) let filteredOutcomes = rulesEngineKnowledgeBase.filter(item => \{ return item.clima === runtimeProfile.clima && item.interes === runtimeProfile.interes && item.floorBudget <= runtimeProfile.presupuesto; \}); if (filteredOutcomes.length === 0) \{ viewportDeck.innerHTML = ` <div style="text-align: center; padding: 35px 15px; color: var(--text-muted);"> <span style="font-size: 3rem;">
